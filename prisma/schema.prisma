generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================================================================
// 🔐 ENUMS & GLOBAL CONFIGURATIONS
// =========================================================================

enum Role {
  CUSTOMER
  EMPLOYEE
  ADMIN
  SUPERADMIN
}

enum EmployeeRole {
  OWNER
  MANAGER
  CASHIER
}

enum PurchaseOrderStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  PAID
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum StockStatus {
  IN_STOCK
  SOLD
  RETURNED
  DAMAGED
  LOST
  CLAIMED
  USED
  MISSING_PENDING_REVIEW
}

enum ServiceStatus {
  RECEIVED
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  CANCELLED
}

enum ReceiptStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  WAITING_APPROVAL
  PAID
  CANCELLED
}

enum PaymentSlipStatus {
  NONE
  WAITING_APPROVAL
  APPROVED
  REJECTED
}

enum LoginType {
  PHONE
  EMAIL
  SOCIAL
  ADMIN
}

enum RefundMethod {
  CASH
  TRANSFER
  CARD
  STORE_CREDIT
  OTHER
}

enum SaleType {
  NORMAL
  GOVERNMENT
  WHOLESALE
}

enum SaleStatus {
  DRAFT
  DELIVERED
  FINALIZED
  COMPLETED
  CANCELLED
}

enum ReturnType {
  REFUND
  CLAIM
  EXCHANGE
  CREDIT_NOTE
  INTERNAL_USE
  STOCK_ERROR
}

enum PaymentType {
  ADVANCE
  RECEIPT_BASED
  CREDIT_NOTE
}

enum OrderOnlineStatus {
  PENDING
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum OrderSource {
  POS
  ONLINE
}

enum CustomerType {
  INDIVIDUAL
  ORGANIZATION
  GOVERNMENT
}

enum BarcodeStatus {
  READY
  SN_RECEIVED
  USED
  VOID
}

enum BusinessType {
  GENERAL
  IT
  ELECTRONICS
  CONSTRUCTION
  GROCERY
}

enum ProductMode {
  SIMPLE
  STRUCTURED
}

enum StockMovementType {
  RECEIVE
  SALE
  ADJUST
  TRANSFER
  RESERVE
  UNRESERVE
  RETURN
  LOSS
}

enum ReceiptSource {
  PO
  QUICK
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  DEPOSIT
  QR
  E_WALLET
  CHEQUE
  OTHER
}

enum DepositStatus {
  ACTIVE
  USED
  CANCELLED
}

enum SaleReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum CombinedBillingStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum BarcodeKind {
  SN
  LOT
}

enum StockAuditMode {
  READY
  FULL
}

enum StockAuditStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SimpleLotStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum CustomerReceiptStatus {
  ACTIVE
  FULLY_ALLOCATED
  CANCELLED
}

// =========================================================================
// 👥 CORE IDENTITIES & ACCESS CONTROL (AUTH & RBAC ENHANCED)
// =========================================================================

model User {
  id          Int       @id @default(autoincrement())
  email       String?   @unique
  loginId     String?   @unique
  password    String
  role        Role
  enabled     Boolean   @default(true)
  lastLoginAt DateTime?
  loginType   LoginType @default(PHONE)

  customerProfile     CustomerProfile?
  employeeProfile     EmployeeProfile?
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orderOnline OrderOnline[]
  cart        Cart[]
}

model EmployeeProfile {
  id    Int     @id @default(autoincrement())
  name  String?
  phone String?

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  // 🛡️ ป้องกันพนักงานหายแล้วระบบลบสาขา บังคับค้างประวัติไว้ก่อน
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Restrict)
  branchId Int?

  position   Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  positionId Int?

  v2Role          EmployeeRole  @default(CASHIER)
  passwordHashV2  String?
  confirmedOrders OrderOnline[] @relation("EmployeeConfirmedOrders")

  purchaseOrderCreated PurchaseOrder[]
  assignedServices     ServiceOrder[]
  approved             Boolean         @default(false)
  active               Boolean         @default(true)

  stockItem                         StockItem[]
  sale                              Sale[]
  saleReturns                       SaleReturn[]
  refundedReturns                   SaleReturn[]                @relation("RefundedBy")
  payment                           Payment[]
  combinedSaleDocument              CombinedSaleDocument[]
  refundTransaction                 RefundTransaction[]
  supplierPayment                   SupplierPayment[]
  createdCustomerReceipts           CustomerReceipt[]           @relation("CustomerReceiptCreatedBy")
  cancelledCustomerReceipts         CustomerReceipt[]           @relation("CustomerReceiptCancelledBy")
  createdCustomerReceiptAllocations CustomerReceiptAllocation[] @relation("CustomerReceiptAllocationCreatedBy")

  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  combinedBillingDocument CombinedBillingDocument[]
  stockAuditSession       StockAuditSession[]
  stockAuditScanLog       StockAuditScanLog[]
  customerDeposit         CustomerDeposit[]
  PurchaseOrderReceipt    PurchaseOrderReceipt[]
  inputTaxFilingBatches   InputTaxFilingBatch[]
  salesTaxFilingBatches   SalesTaxFilingBatch[]
  v2StockAudits           V2StockAudit[]
  repairJobs              RepairJob[]
}

model Branch {
  id           Int     @id @default(autoincrement())
  name         String
  address      String
  phone        String?
  slug         String? @unique
  taxId        String? @db.VarChar(13)
  branchCode   String? @db.VarChar(5)
  isHeadOffice Boolean @default(false)

  subdistrictCode String?
  subdistrict     Subdistrict? @relation(fields: [subdistrictCode], references: [code], onDelete: SetNull)

  categoryId Int      @default(1)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  businessType BusinessType      @default(GENERAL)
  features     Json?
  branchPrices BranchPrice[]
  employees    EmployeeProfile[]
  stock        StockItem[]
  suppliers    Supplier[]
  pos          PurchaseOrder[]
  services     ServiceOrder[]

  RBACEnabled          Boolean                @default(true)
  purchaseOrderReceipt PurchaseOrderReceipt[]
  barcodeCounter       BarcodeCounter[]
  barcodeReceiptItem   BarcodeReceiptItem[]
  sale                 Sale[]
  saleReturn           SaleReturn[]
  payment              Payment[]
  combinedSaleDocument CombinedSaleDocument[]
  refundTransaction    RefundTransaction[]
  supplierPayment      SupplierPayment[]
  customerDeposit      CustomerDeposit[]
  customerReceipts     CustomerReceipt[]
  orderOnline          OrderOnline[]

  combinedBillingDocument CombinedBillingDocument[]
  stockAuditSession       StockAuditSession[]
  paymentCodeCounter      PaymentCodeCounter[]
  stockMovement           StockMovement[]
  simpleLots              SimpleLot[]
  productTypes            ProductType[]

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  stockBalances         StockBalance[]
  inputTaxFilingBatches InputTaxFilingBatch[]
  salesTaxFilingBatches SalesTaxFilingBatch[]
  v2StockAudits         V2StockAudit[]
  repairJobs            RepairJob[]

  @@index([subdistrictCode])
}

// =========================================================================
// 📦 INVENTORY & MULTI-MODE PRODUCT ECOSYSTEM
// =========================================================================

model Category {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  active   Boolean @default(true)
  isSystem Boolean @default(false)

  globalProductTypes GlobalProductType[]
  branches           Branch[]
  productTypes       ProductType[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Product   Product[]
}

model GlobalProductType {
  id     Int     @id @default(autoincrement())
  name   String
  slug   String  @unique
  active Boolean @default(true)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  productTypes ProductType[]

  @@index([categoryId])
  @@index([active])
}

model ProductTypeBrand {
  id            Int          @id @default(autoincrement())
  productTypeId Int
  brandId       Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // 🟢 ผูกความสัมพันธ์เชื่อมตรงแบบ Cascade เพื่อความปลอดภัย
  productType   ProductType  @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  brand         Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([productTypeId, brandId])
  @@index([productTypeId])
  @@index([brandId])
}

model ProductType {
  id                  Int               @id @default(autoincrement())
  name                String
  slug                String
  normalizedName      String?
  active              Boolean           @default(true)

  // 🟢 1. ผูกสายสัมพันธ์กลับไปหา ลำดับสินค้าสากล (GlobalProductType)
  globalProductTypeId Int
  globalProductType   GlobalProductType @relation(fields: [globalProductTypeId], references: [id], onDelete: Restrict)

  // 🟢 2. เปิดท่อเพื่อรองรับตารางสะพานยี่ห้อสินค้า
  productTypeBrands   ProductTypeBrand[]

  categoryId          Int?
  category            Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  branch              Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  branchId            Int?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  Product             Product[]

  @@unique([branchId, categoryId, slug])
  @@unique([branchId, categoryId, normalizedName])
  @@index([branchId])
  @@index([globalProductTypeId])
  @@index([categoryId])
}

model Brand {
  id             Int      @id @default(autoincrement())
  name           String
  normalizedName String   @unique
  active         Boolean  @default(true)

  products       Product[]
  
  // 🟢 เปิดท่อเพื่อให้แบรนด์รับรู้สิทธิ์ในตารางสะพานจับคู่
  productTypeBrands ProductTypeBrand[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active])
  @@index([name])
}

model Product {
  id                Int         @id @default(autoincrement())
  name              String
  mode              ProductMode @default(STRUCTURED)
  noSN              Boolean     @default(false)
  trackSerialNumber Boolean     @default(false)
  active            Boolean     @default(true)

  categoryId    Int?
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productTypeId Int?
  productType   ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)

  brandId Int?
  brand   Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  warrantyDays Int?
  codeType     String?
  unitId       Int?
  unit         Unit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)

  productConfig            Json?
  productImages            ProductImage[]
  stockItems               StockItem[]
  purchaseOrderItems       PurchaseOrderItem[]
  orderItems               ProductOnOrder[]
  cartItems                CartItem[]
  serviceItems             ServiceItem[]
  branchPrice              BranchPrice[]
  orderOnlineItem          OrderOnlineItem[]
  stockAuditSnapshotItem   StockAuditSnapshotItem[]
  stockMovement            StockMovement[]
  saleItemSimple           SaleItemSimple[]
  simpleLots               SimpleLot[]
  stockBalances            StockBalance[]
  PurchaseOrderReceiptItem PurchaseOrderReceiptItem[]
  v2StockAuditItems        V2StockAuditItem[]
  repairPartItems          RepairPartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mode, active])
  @@index([categoryId])
  @@index([productTypeId])
  @@index([brandId])
}

model BranchPrice {
  id              Int       @id @default(autoincrement())
  costPrice       Decimal   @db.Decimal(12, 2)
  priceRetail     Int?
  priceWholesale  Int?
  priceTechnician Int?
  priceOnline     Int?
  effectiveDate   DateTime?
  expiredDate     DateTime?
  note            String?
  updatedBy       Int?
  isActive        Boolean   @default(true)

  // 🛡️ เปลี่ยนราคาแต่ห้ามเคลียร์ตัวสินค้าและสาขาเป็นโดมิโน
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId Int

  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)
  branchId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
}

model StockBalance {
  id               Int      @id @default(autoincrement())
  productId        Int
  branchId         Int
  quantity         Decimal  @default(0) @db.Decimal(12, 2)
  reserved         Decimal  @default(0) @db.Decimal(12, 2)
  avgCost          Decimal? @db.Decimal(12, 2)
  lastReceivedCost Decimal? @db.Decimal(12, 2)

  // 🛡️ ยอดรวมสต๊อกค้ำยันความปลอดภัยข้อมูลสาขาและคลังสินค้าหลัก
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([branchId])
}

model StockMovement {
  id        Int               @id @default(autoincrement())
  productId Int
  branchId  Int
  qty       Decimal           @db.Decimal(12, 2)
  type      StockMovementType
  refType   String?
  refId     Int?
  note      String?
  createdAt DateTime          @default(now())

  // 🛡️ บันทึก Log การเดินสต๊อกประวัติศาสตร์ห้ามหลุดหายเด็ดขาด
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Restrict)

  simpleLotId Int?
  simpleLots  SimpleLot? @relation(fields: [simpleLotId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([productId, createdAt])
  @@index([branchId, type, createdAt])
  @@index([productId, branchId, createdAt])
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  public_id  String   @unique
  url        String
  secure_url String
  active     Boolean  @default(true)
  caption    String?
  isCover    Boolean?

  // 🟢 รูปภาพสินค้าลบตามตัวสินค้าได้เลยเพื่อประหยัดคลาวด์สตอเรจ
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id   Int    @id @default(autoincrement())
  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Product Product[]
}

model StockItem {
  id           Int         @id @default(autoincrement())
  barcode      String      @unique
  serialNumber String?
  qrCodeData   String?
  costPrice    Decimal?    @db.Decimal(12, 2)
  receivedAt   DateTime    @default(now())
  warrantyDays Int?
  expiredAt    DateTime?
  soldAt       DateTime?
  status       StockStatus @default(IN_STOCK)
  remark       String?
  locationCode String?
  source       String?
  tag          String?
  batchNumber  String?
  checkedBy    String?
  color        String?
  scannedAt    DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  scannedByEmployeeId Int?
  scannedBy           EmployeeProfile? @relation(fields: [scannedByEmployeeId], references: [id], onDelete: SetNull)

  // 🛡️ เม็ดสต๊อกรายชิ้นพร้อมเลขอ้างอิงบาร์โค้ดล็อกสิทธิ์แน่นหนา ป้องกันยอดขายและคลังพังทลาย
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  purchaseOrderReceiptItemId Int?
  purchaseOrderReceiptItem   PurchaseOrderReceiptItem? @relation(fields: [purchaseOrderReceiptItemId], references: [id], onDelete: SetNull)

  barcodeReceiptItem     BarcodeReceiptItem[]
  saleItem               SaleItem?
  stockAuditSnapshotItem StockAuditSnapshotItem[]
  stockAuditScanLog      StockAuditScanLog[]
  repairJobs             RepairJob[]
  warrantyClaims         WarrantyClaim[]

  @@unique([serialNumber, productId])
  @@index([branchId, status, productId])
  @@index([productId, status])
}

// =========================================================================
// 📑 RECONCILIATION AUDIT (V2 STOCK AUDITING COMPLIANCE)
// =========================================================================

model V2StockAudit {
  id        Int                @id @default(autoincrement())
  branchId  Int
  branch    Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  auditorId Int
  auditor   EmployeeProfile    @relation(fields: [auditorId], references: [id], onDelete: Restrict)
  status    String             @default("PENDING")
  items     V2StockAuditItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([branchId])
}

model V2StockAuditItem {
  id           Int          @id @default(autoincrement())
  stockAuditId Int
  stockAudit   V2StockAudit @relation(fields: [stockAuditId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  expectedQty  Int
  actualQty    Int
  difference   Int
}

// =========================================================================
// 🤝 PROCUREMENT & FINANCIAL SUPPLY CHAIN
// =========================================================================

model Supplier {
  isSystem      Boolean  @default(false)
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  taxId         String?
  taxBranchCode String?  @default("00000")
  address       String?
  province      String?
  postalCode    String?
  country       String?  @default("Thailand")
  paymentTerms  Int?     @default(0)
  creditLimit   Decimal? @default(0) @db.Decimal(12, 2)
  creditBalance Decimal? @default(0) @db.Decimal(12, 2)
  accountNumber String?
  accountType   String?
  notes         String?
  branchId      Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bankId Int?
  bank   Bank? @relation(fields: [bankId], references: [id], onDelete: SetNull)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  pos                  PurchaseOrder[]
  supplierPayment      SupplierPayment[]
  PurchaseOrderReceipt PurchaseOrderReceipt[]

  @@unique([branchId, name])
}

model Bank {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  supplier  Supplier[]
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PurchaseOrder {
  id         Int                 @id @default(autoincrement())
  code       String              @unique
  date       DateTime            @default(now())
  note       String?
  status     PurchaseOrderStatus @default(PENDING)
  supplierId Int
  branchId   Int
  employeeId Int
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  supplier Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  branch   Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  items    PurchaseOrderItem[]
  receipts PurchaseOrderReceipt[]
}

model PurchaseOrderItem {
  id               Int      @id @default(autoincrement())
  productId        Int
  quantity         Int
  receivedQuantity Int      @default(0)
  costPrice        Decimal  @db.Decimal(12, 2)
  purchaseOrderId  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder PurchaseOrder              @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product                    @relation(fields: [productId], references: [id], onDelete: Restrict)
  receipts      PurchaseOrderReceiptItem[]
}

model PurchaseOrderReceipt {
  id                       Int           @id @default(autoincrement())
  code                     String        @unique
  receivedAt               DateTime      @default(now())
  note                     String?
  totalAmount              Decimal?      @db.Decimal(12, 2)
  paidAmount               Decimal?      @db.Decimal(12, 2)
  supplierTaxInvoiceNumber String?
  supplierTaxInvoiceDate   DateTime?
  vatRate                  Decimal?      @default(7) @db.Decimal(5, 2)
  statusReceipt            ReceiptStatus @default(PENDING)
  statusPayment            PaymentStatus @default(UNPAID)
  receivedById             Int
  printed                  Boolean       @default(false)
  branchId                 Int
  supplierId               Int?
  purchaseOrderId          Int?
  source                   ReceiptSource @default(PO)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  receivedBy    EmployeeProfile @relation(fields: [receivedById], references: [id], onDelete: Restrict)
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier      Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  items                   PurchaseOrderReceiptItem[]
  barcodeReceiptItem      BarcodeReceiptItem[]
  supplierPaymentReceipts SupplierPaymentReceipt[]
  inputTaxFilingItems     InputTaxFilingItem[]

  @@index([branchId, receivedAt])
  @@index([purchaseOrderId])
  @@index([source, receivedAt])
}

model InputTaxFilingBatch {
  id          Int                  @id @default(autoincrement())
  branchId    Int
  month       Int
  year        Int
  status      InputTaxFilingStatus @default(DRAFT)
  note        String?
  createdById Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  branch    Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdBy EmployeeProfile      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     InputTaxFilingItem[]

  @@index([branchId, year, month])
  @@index([status])
}

enum InputTaxFilingStatus {
  DRAFT
  SUBMITTED
  VOIDED
}

model SalesTaxFilingBatch {
  id          Int                  @id @default(autoincrement())
  branchId    Int
  month       Int
  year        Int
  status      SalesTaxFilingStatus @default(DRAFT)
  note        String?
  createdById Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  branch    Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdBy EmployeeProfile      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     SalesTaxFilingItem[]

  @@index([branchId, year, month])
  @@index([status])
}

enum SalesTaxFilingStatus {
  DRAFT
  SUBMITTED
  VOIDED
}

model SalesTaxFilingItem {
  id        Int      @id @default(autoincrement())
  batchId   Int
  saleId    Int
  createdAt DateTime @default(now())

  batch SalesTaxFilingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sale  Sale                @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@unique([batchId, saleId])
  @@index([saleId])
}

model InputTaxFilingItem {
  id                     Int      @id @default(autoincrement())
  batchId                Int
  purchaseOrderReceiptId Int
  createdAt              DateTime @default(now())

  batch   InputTaxFilingBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  receipt PurchaseOrderReceipt @relation(fields: [purchaseOrderReceiptId], references: [id], onDelete: Restrict)

  @@unique([batchId, purchaseOrderReceiptId])
  @@index([purchaseOrderReceiptId])
}

model PurchaseOrderReceiptItem {
  id                  Int      @id @default(autoincrement())
  receiptId           Int
  purchaseOrderItemId Int?
  productId           Int?
  quantity            Decimal  @db.Decimal(12, 2)
  costPrice           Decimal  @db.Decimal(12, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  receipt            PurchaseOrderReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderItem  PurchaseOrderItem?   @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)
  product            Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  stockItems         StockItem[]
  barcodeReceiptItem BarcodeReceiptItem[]
  simpleLots         SimpleLot[]

  @@index([receiptId])
  @@index([productId])
}

// =========================================================================
// 🛒 CUSTOMER SERVICES, BILLING & LOGISTICS
// =========================================================================

model Order {
