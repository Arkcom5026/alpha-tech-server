model District {
  code         String        @id
  nameTh       String
  provinceCode String
  createdAt    DateTime      @default(now()) @map("created_at")
  province     Province      @relation(fields: [provinceCode], references: [code], onDelete: Cascade)
  subdistricts Subdistrict[]

  @@index([provinceCode])
}

model Subdistrict {
  code            String            @id
  nameTh          String
  districtCode    String
  postcode        String?
  branches        Branch[]
  CustomerProfile CustomerProfile[]
  district        District          @relation(fields: [districtCode], references: [code], onDelete: Cascade)

  @@index([districtCode])
  @@index([postcode])
}

model Position {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  description String?
  isActive    Boolean           @default(true)
  employees   EmployeeProfile[]

  @@index([isActive])
  @@index([name])
}

model RepairJob {
  id                     Int                          @id @default(autoincrement())
  jobNo                  String
  serviceCaseId          Int?
  branchId               Int
  customerId             Int
  stockItemId            Int?
  status                 RepairJobStatus              @default(DRAFT)
  reportedSymptoms       String
  intakeNote             String?
  technicianNotes        String?
  estimatedCost          Decimal                      @default(0.0) @db.Decimal(12, 2)
  depositPaid            Decimal                      @default(0.0) @db.Decimal(12, 2)
  finalLaborAmount       Decimal                      @default(0.0) @db.Decimal(12, 2)
  finalPartsAmount       Decimal                      @default(0.0) @db.Decimal(12, 2)
  finalDiscountAmount    Decimal                      @default(0.0) @db.Decimal(12, 2)
  finalTotalAmount       Decimal                      @default(0.0) @db.Decimal(12, 2)
  technicianId           Int?
  receivedByEmployeeId   Int?
  receivedAt             DateTime?
  diagnosisCompletedAt   DateTime?
  readyForPickupAt       DateTime?
  deliveredAt            DateTime?
  closedAt               DateTime?
  cancelledAt            DateTime?
  closeOutcome           RepairCloseOutcome?
  followUpRecommendation RepairFollowUpRecommendation @default(NONE)
  version                Int                          @default(1)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  serviceCase            ServiceCase?                 @relation(fields: [serviceCaseId], references: [id], onDelete: Restrict)
  branch                 Branch                       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer               CustomerProfile              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  stockItem              StockItem?                   @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  technician             EmployeeProfile?             @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  receivedBy             EmployeeProfile?             @relation("RepairJobReceivedBy", fields: [receivedByEmployeeId], references: [id], onDelete: Restrict)
  device                 RepairDevice?
  accessories            RepairAccessory[]
  evidences              RepairEvidence[]
  diagnoses              RepairDiagnosis[]
  estimates              RepairEstimate[]
  workItems              RepairWorkItem[]
  events                 RepairJobEvent[]
  partsUsed              RepairPartItem[]
  custodyEvents          RepairCustodyEvent[]
  warrantyClaims         WarrantyClaim[]
  followUpSaleReturns    SaleReturn[]                 @relation("SaleReturnSourceRepairJob")
  deliveryConfirmation   RepairDeliveryConfirmation?
  completionCommand      RepairCompletionCommand?
  RepairApproval         RepairApproval[]

  @@unique([branchId, jobNo])
  @@index([serviceCaseId])
  @@index([branchId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([stockItemId])
  @@index([technicianId, status])
  @@index([receivedByEmployeeId])
}

model RepairPartItem {
  id                 Int              @id @default(autoincrement())
  repairJobId        Int
  repairWorkItemId   Int?
  productId          Int
  stockItemId        Int?
  simpleLotId        Int?
  qtyIssued          Decimal          @default(1) @db.Decimal(12, 2)
  qtyUsed            Decimal          @default(1) @db.Decimal(12, 2)
  qtyReturned        Decimal          @default(0) @db.Decimal(12, 2)
  unitCost           Decimal?         @db.Decimal(12, 2)
  unitPrice          Decimal          @db.Decimal(12, 2)
  issuedByEmployeeId Int?
  issuedAt           DateTime         @default(now())
  returnedAt         DateTime?
  note               String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  product            Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  repairJob          RepairJob        @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  repairWorkItem     RepairWorkItem?  @relation(fields: [repairWorkItemId], references: [id], onDelete: Restrict)
  stockItem          StockItem?       @relation("RepairPartStockItem", fields: [stockItemId], references: [id], onDelete: Restrict)
  simpleLot          SimpleLot?       @relation(fields: [simpleLotId], references: [id], onDelete: Restrict)
  issuedBy           EmployeeProfile? @relation("RepairPartIssuedBy", fields: [issuedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([repairJobId, issuedAt])
  @@index([repairWorkItemId])
  @@index([productId])
  @@index([stockItemId])
  @@index([simpleLotId])
  @@index([issuedByEmployeeId])
}

model RepairDevice {
  id                         Int       @id @default(autoincrement())
  repairJobId                Int       @unique
  deviceType                 String
  brand                      String?
  model                      String?
  serialNumber               String?
  imei                       String?
  serviceTag                 String?
  color                      String?
  customerDeclaredPurchaseAt DateTime?
  proofOfPurchaseReference   String?
  intakeCondition            String?
  dataRiskAcknowledgedAt     DateTime?
  unlockSecretReference      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  repairJob                  RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Cascade)

  @@index([serialNumber])
  @@index([imei])
  @@index([serviceTag])
}

model RepairAccessory {
  id          Int       @id @default(autoincrement())
  repairJobId Int
  name        String
  quantity    Int       @default(1)
  condition   String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  repairJob   RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Cascade)

  @@index([repairJobId])
}

model RepairEvidence {
  id                  Int                @id @default(autoincrement())
  repairJobId         Int
  evidenceType        RepairEvidenceType
  storageKey          String
  fileName            String?
  mimeType            String?
  caption             String?
  occurredAt          DateTime           @default(now())
  createdByEmployeeId Int?
  metadata            Json?
  createdAt           DateTime           @default(now())
  repairJob           RepairJob          @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  createdBy           EmployeeProfile?   @relation("RepairEvidenceCreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: Restrict)

  @@index([repairJobId, occurredAt])
  @@index([createdByEmployeeId])
}

model RepairDiagnosis {
  id                    Int                       @id @default(autoincrement())
  repairJobId           Int
  sequence              Int
  observedSymptoms      String?
  diagnosis             String
  rootCause             String?
  recommendedAction     RepairRecommendedAction
  warrantyEligibility   RepairWarrantyEligibility @default(UNKNOWN)
  warrantySource        String?
  warrantyExpiresAt     DateTime?
  diagnosisNote         String?
  diagnosedByEmployeeId Int?
  diagnosedAt           DateTime                  @default(now())
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  repairJob             RepairJob                 @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  diagnosedBy           EmployeeProfile?          @relation("RepairDiagnosisDiagnosedBy", fields: [diagnosedByEmployeeId], references: [id], onDelete: Restrict)
  warrantyClaims        WarrantyClaim[]

  @@unique([repairJobId, sequence])
  @@index([repairJobId, diagnosedAt])
  @@index([diagnosedByEmployeeId])
  @@index([warrantyEligibility])
}

model RepairEstimate {
  id                  Int                  @id @default(autoincrement())
  repairJobId         Int
  revision            Int
  status              RepairEstimateStatus @default(DRAFT)
  laborAmount         Decimal              @default(0) @db.Decimal(12, 2)
  partsAmount         Decimal              @default(0) @db.Decimal(12, 2)
  otherAmount         Decimal              @default(0) @db.Decimal(12, 2)
  discountAmount      Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal              @default(0) @db.Decimal(12, 2)
  validUntil          DateTime?
  note                String?
  createdByEmployeeId Int?
  offeredAt           DateTime?
  supersededAt        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  repairJob           RepairJob            @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  createdBy           EmployeeProfile?     @relation("RepairEstimateCreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: Restrict)
  items               RepairEstimateItem[]
  approval            RepairApproval?

  @@unique([repairJobId, revision])
  @@index([repairJobId, status, createdAt])
  @@index([createdByEmployeeId])
}

model RepairEstimateItem {
  id          Int                    @id @default(autoincrement())
  estimateId  Int
  itemType    RepairEstimateItemType
  description String
  quantity    Decimal                @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal                @db.Decimal(12, 2)
  lineTotal   Decimal                @db.Decimal(12, 2)
  productId   Int?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  estimate    RepairEstimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  product     Product?               @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([estimateId])
  @@index([productId])
}

model RepairApproval {
  id                   Int                    @id @default(autoincrement())
  repairEstimateId     Int                    @unique
  repairJobId          Int
  customerId           Int
  decision             RepairApprovalDecision
  approvalMethod       RepairApprovalMethod
  approvedAmount       Decimal?               @db.Decimal(12, 2)
  note                 String?
  evidenceReference    String?
  recordedByEmployeeId Int?
  decidedAt            DateTime               @default(now())
  createdAt            DateTime               @default(now())
  repairEstimate       RepairEstimate         @relation(fields: [repairEstimateId], references: [id], onDelete: Restrict)
  repairJob            RepairJob              @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  customer             CustomerProfile        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  recordedBy           EmployeeProfile?       @relation("RepairApprovalRecordedBy", fields: [recordedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([repairJobId, decidedAt])
  @@index([customerId, decidedAt])
  @@index([recordedByEmployeeId])
}

model RepairWorkItem {
  id                   Int                  @id @default(autoincrement())
  repairJobId          Int
  sequence             Int
  type                 RepairWorkItemType
  status               RepairWorkItemStatus @default(PENDING)
  title                String
  description          String?
  assignedToEmployeeId Int?
  estimatedAmount      Decimal?             @db.Decimal(12, 2)
  actualAmount         Decimal?             @db.Decimal(12, 2)
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  repairJob            RepairJob            @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  assignedTo           EmployeeProfile?     @relation("RepairWorkItemAssignedTo", fields: [assignedToEmployeeId], references: [id], onDelete: Restrict)
  partsUsed            RepairPartItem[]
  warrantyClaim        WarrantyClaim?

  @@unique([repairJobId, sequence])
  @@index([repairJobId, status, sequence])
  @@index([assignedToEmployeeId, status])
}

model RepairJobEvent {
  id                    Int                @id @default(autoincrement())
  repairJobId           Int
  eventType             RepairJobEventType
  fromStatus            RepairJobStatus?
  toStatus              RepairJobStatus?
  note                  String?
  occurredAt            DateTime           @default(now())
  performedByEmployeeId Int?
  metadata              Json?
  createdAt             DateTime           @default(now())
  repairJob             RepairJob          @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  performedBy           EmployeeProfile?   @relation("RepairJobEventPerformedBy", fields: [performedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([repairJobId, occurredAt])
  @@index([performedByEmployeeId, occurredAt])
  @@index([eventType, occurredAt])
}

model RepairCustodyEvent {
  id                    Int                  @id @default(autoincrement())
  serviceCaseId         Int?
  repairJobId           Int
  warrantyClaimId       Int?
  fromCustodianType     RepairCustodianType?
  fromCustodianRef      String?
  toCustodianType       RepairCustodianType
  toCustodianRef        String?
  transferReference     String?
  trackingNumber        String?
  transferredAt         DateTime             @default(now())
  receivedAt            DateTime?
  note                  String?
  performedByEmployeeId Int?
  metadata              Json?
  createdAt             DateTime             @default(now())
  serviceCase           ServiceCase?         @relation(fields: [serviceCaseId], references: [id], onDelete: Restrict)
  repairJob             RepairJob            @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  warrantyClaim         WarrantyClaim?       @relation(fields: [warrantyClaimId], references: [id], onDelete: Restrict)
  performedBy           EmployeeProfile?     @relation("RepairCustodyEventPerformedBy", fields: [performedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([serviceCaseId, transferredAt])
  @@index([repairJobId, transferredAt])
  @@index([warrantyClaimId, transferredAt])
  @@index([performedByEmployeeId])
}

model RepairDeliveryConfirmation {
  id                    Int              @id @default(autoincrement())
  repairJobId           Int              @unique
  customerId            Int
  recipientName         String
  recipientPhone        String?
  recipientRelationship String?
  resultSummary         String?
  remainingIssueNote    String?
  customerAccepted      Boolean          @default(false)
  signatureReference    String?
  confirmedByEmployeeId Int?
  deliveredAt           DateTime         @default(now())
  createdAt             DateTime         @default(now())
  repairJob             RepairJob        @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  customer              CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  confirmedBy           EmployeeProfile? @relation("RepairDeliveryConfirmedBy", fields: [confirmedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([customerId, deliveredAt])
  @@index([confirmedByEmployeeId])
}

model RepairCompletionCommand {
  id          Int       @id @default(autoincrement())
  branchId    Int
  commandKey  String
  requestHash String
  repairJobId Int       @unique
  createdAt   DateTime  @default(now())
  completedAt DateTime  @default(now())
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  repairJob   RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Restrict)

  @@unique([branchId, commandKey])
  @@index([branchId, createdAt])
}

model WarrantyClaim {
  id                     Int                             @id @default(autoincrement())
  branchId               Int
  stockItemId            Int
  supplierId             Int?
  repairJobId            Int
  repairWorkItemId       Int?                            @unique
  repairDiagnosisId      Int?
  previousClaimId        Int?
  claimNo                String
  status                 WarrantyClaimStatus             @default(DRAFT)
  reason                 String
  serviceProvider        String?
  externalClaimRef       String?
  trackingNumber         String?
  resolution             WarrantyClaimResolution?
  resolutionNote         String?
  replacementStockItemId Int?
  creditAmount           Decimal?                        @db.Decimal(12, 2)
  eligibilitySnapshot    Json?
  openedAt               DateTime                        @default(now())
  submittedAt            DateTime?
  providerReceivedAt     DateTime?
  resolvedAt             DateTime?
  cancelledAt            DateTime?
  createdByEmployeeId    Int?
  resolvedByEmployeeId   Int?
  version                Int                             @default(1)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  branch                 Branch                          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  stockItem              StockItem                       @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  supplier               Supplier?                       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  repairJob              RepairJob                       @relation(fields: [repairJobId], references: [id], onDelete: Restrict)
  repairWorkItem         RepairWorkItem?                 @relation(fields: [repairWorkItemId], references: [id], onDelete: Restrict)
  repairDiagnosis        RepairDiagnosis?                @relation(fields: [repairDiagnosisId], references: [id], onDelete: Restrict)
  previousClaim          WarrantyClaim?                  @relation("WarrantyClaimHistory", fields: [previousClaimId], references: [id], onDelete: Restrict)
  subsequentClaims       WarrantyClaim[]                 @relation("WarrantyClaimHistory")
  replacementStockItem   StockItem?                      @relation("WarrantyClaimReplacementStockItem", fields: [replacementStockItemId], references: [id], onDelete: Restrict)
  createdBy              EmployeeProfile?                @relation("WarrantyClaimCreatedBy", fields: [createdByEmployeeId], references: [id], onDelete: Restrict)
  resolvedBy             EmployeeProfile?                @relation("WarrantyClaimResolvedBy", fields: [resolvedByEmployeeId], references: [id], onDelete: Restrict)
  events                 WarrantyClaimEvent[]
  completionCommand      WarrantyClaimCompletionCommand?
  custodyEvents          RepairCustodyEvent[]

  @@unique([branchId, claimNo])
  @@index([stockItemId, openedAt])
  @@index([supplierId, openedAt])
  @@index([repairJobId, openedAt])
  @@index([repairDiagnosisId])
  @@index([previousClaimId])
  @@index([replacementStockItemId])
  @@index([createdByEmployeeId])
  @@index([resolvedByEmployeeId])
  @@index([branchId, status, openedAt])
}

model WarrantyClaimEvent {
  id                    Int                 @id @default(autoincrement())
  warrantyClaimId       Int
  status                WarrantyClaimStatus
  note                  String?
  occurredAt            DateTime            @default(now())
  performedByEmployeeId Int?
  metadata              Json?
  createdAt             DateTime            @default(now())
  warrantyClaim         WarrantyClaim       @relation(fields: [warrantyClaimId], references: [id], onDelete: Restrict)
  performedBy           EmployeeProfile?    @relation(fields: [performedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([warrantyClaimId, occurredAt])
  @@index([performedByEmployeeId, occurredAt])
}

model WarrantyClaimCompletionCommand {
  id              Int           @id @default(autoincrement())
  branchId        Int
  commandKey      String
  requestHash     String
  warrantyClaimId Int           @unique
  createdAt       DateTime      @default(now())
  completedAt     DateTime      @default(now())
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  warrantyClaim   WarrantyClaim @relation(fields: [warrantyClaimId], references: [id], onDelete: Restrict)

  @@unique([branchId, commandKey])
  @@index([branchId, createdAt])
}

model ServiceCase {
  id                   Int                           @id @default(autoincrement())
  caseNo               String
  branchId             Int
  customerId           Int?
  primaryStockItemId   Int?
  status               ServiceCaseStatus             @default(DRAFT)
  priority             ServiceCasePriority           @default(NORMAL)
  intakeChannel        ServiceCaseIntakeChannel      @default(WALK_IN)
  summary              String
  description          String?
  currentCustodianType ServiceCustodianType?
  currentCustodianRef  String?
  currentLocationNote  String?
  openedByEmployeeId   Int?
  closedByEmployeeId   Int?
  openedAt             DateTime                      @default(now())
  closedAt             DateTime?
  cancelledAt          DateTime?
  version              Int                           @default(1)
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  branch               Branch                        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer             CustomerProfile?              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  primaryStockItem     StockItem?                    @relation("ServiceCasePrimaryStockItem", fields: [primaryStockItemId], references: [id], onDelete: Restrict)
  openedBy             EmployeeProfile?              @relation("ServiceCaseOpenedBy", fields: [openedByEmployeeId], references: [id], onDelete: Restrict)
  closedBy             EmployeeProfile?              @relation("ServiceCaseClosedBy", fields: [closedByEmployeeId], references: [id], onDelete: Restrict)
  assets               ServiceCaseAsset[]
  events               ServiceCaseEvent[]
  custodyEvents        ServiceCaseCustodyEvent[]
  repairJobs           RepairJob[]
  relatedFrom          ServiceCaseLink[]             @relation("ServiceCaseLinkFrom")
  relatedTo            ServiceCaseLink[]             @relation("ServiceCaseLinkTo")
  completionCommand    ServiceCaseCompletionCommand?
  RepairCustodyEvent   RepairCustodyEvent[]

  @@unique([branchId, caseNo])
  @@index([branchId, status, openedAt])
  @@index([customerId, openedAt])
  @@index([primaryStockItemId, openedAt])
  @@index([openedByEmployeeId])
  @@index([closedByEmployeeId])
}

model ServiceCaseAsset {
  id                       Int                       @id @default(autoincrement())
  serviceCaseId            Int
  stockItemId              Int?
  role                     ServiceCaseAssetRole      @default(PRIMARY)
  assetType                String
  brand                    String?
  model                    String?
  serialNumber             String?
  imei                     String?
  serviceTag               String?
  color                    String?
  ownershipType            ServiceAssetOwnershipType @default(CUSTOMER_OWNED)
  proofOfPurchaseReference String?
  intakeCondition          String?
  identitySnapshot         Json?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  serviceCase              ServiceCase               @relation(fields: [serviceCaseId], references: [id], onDelete: Restrict)
  stockItem                StockItem?                @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  custodyEvents            ServiceCaseCustodyEvent[]

  @@index([serviceCaseId, role])
  @@index([stockItemId])
  @@index([serialNumber])
  @@index([imei])
  @@index([serviceTag])
}

model ServiceCaseEvent {
  id                    Int                   @id @default(autoincrement())
  serviceCaseId         Int
  eventType             ServiceCaseEventType
  fromStatus            ServiceCaseStatus?
  toStatus              ServiceCaseStatus?
  sourceType            ServiceCaseSourceType @default(SERVICE_CASE)
  sourceRefId           Int?
  correlationKey        String?
  note                  String?
  occurredAt            DateTime              @default(now())
  performedByEmployeeId Int?
  metadata              Json?
  createdAt             DateTime              @default(now())
  serviceCase           ServiceCase           @relation(fields: [serviceCaseId], references: [id], onDelete: Restrict)
  performedBy           EmployeeProfile?      @relation("ServiceCaseEventPerformedBy", fields: [performedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([serviceCaseId, occurredAt])
  @@index([sourceType, sourceRefId, occurredAt])
  @@index([correlationKey])
  @@index([performedByEmployeeId, occurredAt])
}

model ServiceCaseCustodyEvent {
  id                    Int                   @id @default(autoincrement())
  serviceCaseId         Int
  serviceCaseAssetId    Int?
  fromCustodianType     ServiceCustodianType?
  fromCustodianRef      String?
  toCustodianType       ServiceCustodianType
  toCustodianRef        String?
  transferReference     String?
  trackingNumber        String?
  transferredAt         DateTime              @default(now())
  receivedAt            DateTime?
  note                  String?
  performedByEmployeeId Int?
  metadata              Json?
  createdAt             DateTime              @default(now())
  serviceCase           ServiceCase           @relation(fields: [serviceCaseId], references: [id], onDelete: Restrict)
  serviceCaseAsset      ServiceCaseAsset?     @relation(fields: [serviceCaseAssetId], references: [id], onDelete: Restrict)
  performedBy           EmployeeProfile?      @relation("ServiceCaseCustodyEventPerformedBy", fields: [performedByEmployeeId], references: [id], onDelete: Restrict)

  @@index([serviceCaseId, transferredAt])
  @@index([serviceCaseAssetId, transferredAt])
  @@index([performedByEmployeeId])
}

model ServiceCaseLink {
  id                Int                 @id @default(autoincrement())
  fromServiceCaseId Int
  toServiceCaseId   Int
  linkType          ServiceCaseLinkType
  note              String?
  createdAt         DateTime            @default(now())
  fromServiceCase   ServiceCase         @relation("ServiceCaseLinkFrom", fields: [fromServiceCaseId], references: [id], onDelete: Restrict)
  toServiceCase     ServiceCase         @relation("ServiceCaseLinkTo", fields: [toServiceCaseId], references: [id], onDelete: Restrict)

  @@unique([fromServiceCaseId, toServiceCaseId, linkType])
  @@index([toServiceCaseId, linkType])
}

model ServiceCaseCompletionCommand {
  id            Int         @id @default(autoincrement())
  branchId      Int
  commandKey    String
  requestHash   String
  serviceCaseId Int         @unique
  createdAt     DateTime    @default(now())
  completedAt   DateTime    @default(now())
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  serviceCase   ServiceCase @relation(fields: [serviceCaseId], references: [id], onDelete: Restrict)

  @@unique([branchId, commandKey])
  @@index([branchId, createdAt])
}

enum ServiceCaseStatus {
  DRAFT
  OPEN
  TRIAGE
  DIAGNOSING
  WAITING_CUSTOMER
  IN_SERVICE
  WAITING_EXTERNAL
  QUALITY_CHECK
  READY_FOR_DELIVERY
  DELIVERED
  CLOSED
  CANCELLED
}

enum ServiceCasePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ServiceCaseIntakeChannel {
  WALK_IN
  PHONE
  ONLINE
  DELIVERY
  INTERNAL
}

enum ServiceCaseAssetRole {
  PRIMARY
  COMPONENT
  ACCESSORY
  REPLACEMENT
  LOANER
}

enum ServiceAssetOwnershipType {
