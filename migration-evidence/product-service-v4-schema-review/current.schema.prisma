generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String?              @unique
  password            String
  role                Role
  enabled             Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  loginId             String?              @unique
  loginType           LoginType            @default(PHONE)
  cart                Cart[]
  customerProfile     CustomerProfile?
  employeeProfile     EmployeeProfile?
  orderOnline         OrderOnline[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
}

model EmployeeProfile {
  openedServiceCases                ServiceCase[]                @relation("ServiceCaseOpenedBy")
  closedServiceCases                ServiceCase[]                @relation("ServiceCaseClosedBy")
  performedServiceCaseEvents        ServiceCaseEvent[]           @relation("ServiceCaseEventPerformedBy")
  performedServiceCaseCustodyEvents ServiceCaseCustodyEvent[]    @relation("ServiceCaseCustodyEventPerformedBy")
  id                                Int                          @id @default(autoincrement())
  name                              String?
  phone                             String?
  userId                            Int                          @unique
  branchId                          Int?
  positionId                        Int?
  createdAt                         DateTime                     @default(now())
  updatedAt                         DateTime                     @updatedAt
  approved                          Boolean                      @default(false)
  active                            Boolean                      @default(true)
  passwordHashV2                    String?
  v2Role                            EmployeeRole                 @default(CASHIER)
  combinedBillingDocument           CombinedBillingDocument[]
  combinedSaleDocument              CombinedSaleDocument[]
  customerDeposit                   CustomerDeposit[]
  createdCustomerReceiptAllocations CustomerReceiptAllocation[]  @relation("CustomerReceiptAllocationCreatedBy")
  cancelledCustomerReceipts         CustomerReceipt[]            @relation("CustomerReceiptCancelledBy")
  createdCustomerReceipts           CustomerReceipt[]            @relation("CustomerReceiptCreatedBy")
  branch                            Branch?                      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  position                          Position?                    @relation(fields: [positionId], references: [id])
  user                              User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  inputTaxFilingBatches             InputTaxFilingBatch[]
  confirmedOrders                   OrderOnline[]                @relation("EmployeeConfirmedOrders")
  payment                           Payment[]
  purchaseOrderCreated              PurchaseOrder[]
  PurchaseOrderReceipt              PurchaseOrderReceipt[]
  refundTransaction                 RefundTransaction[]
  repairJobs                        RepairJob[]
  receivedRepairJobs                RepairJob[]                  @relation("RepairJobReceivedBy")
  diagnosedRepairJobs               RepairDiagnosis[]            @relation("RepairDiagnosisDiagnosedBy")
  createdRepairEstimates            RepairEstimate[]             @relation("RepairEstimateCreatedBy")
  repairApprovals                   RepairApproval[]             @relation("RepairApprovalRecordedBy")
  assignedRepairWorkItems           RepairWorkItem[]             @relation("RepairWorkItemAssignedTo")
  performedRepairJobEvents          RepairJobEvent[]             @relation("RepairJobEventPerformedBy")
  issuedRepairParts                 RepairPartItem[]             @relation("RepairPartIssuedBy")
  performedRepairCustodyEvents      RepairCustodyEvent[]         @relation("RepairCustodyEventPerformedBy")
  confirmedRepairDeliveries         RepairDeliveryConfirmation[] @relation("RepairDeliveryConfirmedBy")
  createdRepairEvidences            RepairEvidence[]             @relation("RepairEvidenceCreatedBy")
  sale                              Sale[]
  saleReturns                       SaleReturn[]
  performedStockMovements           StockMovement[]
  createdWarrantyClaims             WarrantyClaim[]              @relation("WarrantyClaimCreatedBy")
  resolvedWarrantyClaims            WarrantyClaim[]              @relation("WarrantyClaimResolvedBy")
  performedWarrantyClaimEvents      WarrantyClaimEvent[]
  refundedReturns                   SaleReturn[]                 @relation("RefundedBy")
  salesTaxFilingBatches             SalesTaxFilingBatch[]
  assignedServices                  ServiceOrder[]
  stockAuditScanLog                 StockAuditScanLog[]
  stockAuditSession                 StockAuditSession[]
  stockItem                         StockItem[]
  supplierPayment                   SupplierPayment[]
  v2StockAudits                     V2StockAudit[]
}

model Branch {
  id                              Int                              @id @default(autoincrement())
  name                            String
  address                         String
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  RBACEnabled                     Boolean                          @default(true)
  phone                           String?
  subdistrictCode                 String?
  businessType                    BusinessType                     @default(GENERAL)
  features                        Json?
  branchCode                      String?                          @db.VarChar(5)
  isHeadOffice                    Boolean                          @default(false)
  taxId                           String?                          @db.VarChar(13)
  slug                            String?                          @unique
  categoryId                      Int                              @default(1)
  barcodeCounter                  BarcodeCounter[]
  barcodeReceiptItem              BarcodeReceiptItem[]
  category                        Category                         @relation(fields: [categoryId], references: [id])
  subdistrict                     Subdistrict?                     @relation(fields: [subdistrictCode], references: [code])
  branchPrices                    BranchPrice[]
  combinedBillingDocument         CombinedBillingDocument[]
  combinedSaleDocument            CombinedSaleDocument[]
  customerDeposit                 CustomerDeposit[]
  customerReceipts                CustomerReceipt[]
  employees                       EmployeeProfile[]
  inputTaxFilingBatches           InputTaxFilingBatch[]
  orderOnline                     OrderOnline[]
  payment                         Payment[]
  paymentCodeCounter              PaymentCodeCounter[]
  productTypes                    ProductType[]
  pos                             PurchaseOrder[]
  purchaseOrderReceipt            PurchaseOrderReceipt[]
  refundTransaction               RefundTransaction[]
  repairJobs                      RepairJob[]
  repairCompletionCommands        RepairCompletionCommand[]
  sale                            Sale[]
  salesCompletionCommands         SalesCompletionCommand[]
  saleReturn                      SaleReturn[]
  saleReturnCompletionCommands    SaleReturnCompletionCommand[]
  warrantyClaims                  WarrantyClaim[]
  warrantyClaimCompletionCommands WarrantyClaimCompletionCommand[]
  salesTaxFilingBatches           SalesTaxFilingBatch[]
  services                        ServiceOrder[]
  simpleLots                      SimpleLot[]
  stockAuditSession               StockAuditSession[]
  stockBalances                   StockBalance[]
  stock                           StockItem[]
  stockMovement                   StockMovement[]
  suppliers                       Supplier[]
  supplierPayment                 SupplierPayment[]
  v2StockAudits                   V2StockAudit[]
  serviceCases                    ServiceCase[]
  serviceCaseCompletionCommands   ServiceCaseCompletionCommand[]

  @@index([subdistrictCode])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  active    Boolean  @default(true)
  isSystem  Boolean  @default(false)

  branches           Branch[]
  globalProductTypes GlobalProductType[]
}

model GlobalProductType {
  id           Int           @id @default(autoincrement())
  name         String
  slug         String        @unique
  active       Boolean       @default(true)
  categoryId   Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  category     Category      @relation(fields: [categoryId], references: [id])
  productTypes ProductType[]

  @@index([categoryId])
  @@index([active])
}

model ProductTypeBrand {
  id            Int         @id @default(autoincrement())
  productTypeId Int
  brandId       Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  brand         Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  productType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)

  @@unique([productTypeId, brandId])
  @@index([productTypeId])
  @@index([brandId])
}

model ProductType {
  id                  Int      @id @default(autoincrement())
  name                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  active              Boolean  @default(true)
  guideExamples       String[] @default([])
  normalizedName      String?
  pathCached          String?
  branchId            Int?
  globalProductTypeId Int

  Product           Product[]
  branch            Branch?            @relation(fields: [branchId], references: [id])
  globalProductType GlobalProductType  @relation(fields: [globalProductTypeId], references: [id])
  productTypeBrands ProductTypeBrand[]

  @@unique([branchId, globalProductTypeId, normalizedName])
  @@index([branchId])
  @@index([globalProductTypeId])
}

model Brand {
  id                Int                @id @default(autoincrement())
  name              String
  normalizedName    String             @unique
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  products          Product[]
  productTypeBrands ProductTypeBrand[]

  @@index([active])
  @@index([name])
}

model Product {
  id                       Int                        @id @default(autoincrement())
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  noSN                     Boolean                    @default(false)
  active                   Boolean                    @default(true)
  name                     String
  mode                     ProductMode                @default(STRUCTURED)
  trackSerialNumber        Boolean                    @default(false)
  productTypeId            Int?
  brandId                  Int?
  codeType                 String?
  productConfig            Json?
  unitId                   Int?
  warrantyDays             Int?
  templateProductId        Int?
  branchPrice              BranchPrice[]
  cartItems                CartItem[]
  orderOnlineItem          OrderOnlineItem[]
  brand                    Brand?                     @relation(fields: [brandId], references: [id])
  productType              ProductType?               @relation(fields: [productTypeId], references: [id])
  templateProduct          Product?                   @relation("ProductTemplateClone", fields: [templateProductId], references: [id], onUpdate: NoAction)
  clonedProducts           Product[]                  @relation("ProductTemplateClone")
  unit                     Unit?                      @relation(fields: [unitId], references: [id])
  productImages            ProductImage[]
  orderItems               ProductOnOrder[]
  purchaseOrderItems       PurchaseOrderItem[]
  PurchaseOrderReceiptItem PurchaseOrderReceiptItem[]
  repairPartItems          RepairPartItem[]
  repairEstimateItems      RepairEstimateItem[]
  saleItemSimple           SaleItemSimple[]
  serviceItems             ServiceItem[]
  simpleLots               SimpleLot[]
  stockAuditSnapshotItem   StockAuditSnapshotItem[]
  stockBalances            StockBalance[]
  stockItems               StockItem[]
  stockMovement            StockMovement[]
  v2StockAuditItems        V2StockAuditItem[]

  @@index([mode, active])
  @@index([productTypeId])
  @@index([brandId])
  @@index([templateProductId])
}

model BranchPrice {
  id              Int       @id @default(autoincrement())
  productId       Int
  branchId        Int
  effectiveDate   DateTime?
  expiredDate     DateTime?
  note            String?
  updatedBy       Int?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  costPrice       Decimal   @db.Decimal(12, 2)
  priceOnline     Int?
  priceRetail     Int?
  priceTechnician Int?
  priceWholesale  Int?
  branch          Branch    @relation(fields: [branchId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])

  @@unique([productId, branchId])
}

model StockBalance {
  id               Int      @id @default(autoincrement())
  productId        Int
  branchId         Int
  quantity         Decimal  @default(0) @db.Decimal(12, 2)
  reserved         Decimal  @default(0) @db.Decimal(12, 2)
  avgCost          Decimal? @db.Decimal(12, 2)
  lastReceivedCost Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  branch           Branch   @relation(fields: [branchId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])

  @@unique([productId, branchId])
  @@index([branchId])
}

model StockMovement {
  id                    Int               @id @default(autoincrement())
  productId             Int
  branchId              Int
  qty                   Decimal           @db.Decimal(12, 2)
  type                  StockMovementType
  refType               String?
  refId                 Int?
  note                  String?
  createdAt             DateTime          @default(now())
  simpleLotId           Int?
  stockItemId           Int?
  previousStockStatus   StockStatus?
  resultingStockStatus  StockStatus?
  performedByEmployeeId Int?
  occurredAt            DateTime          @default(now())
  branch                Branch            @relation(fields: [branchId], references: [id])
  product               Product           @relation(fields: [productId], references: [id])
  simpleLots            SimpleLot?        @relation(fields: [simpleLotId], references: [id])
  stockItem             StockItem?        @relation(fields: [stockItemId], references: [id])
  performedBy           EmployeeProfile?  @relation(fields: [performedByEmployeeId], references: [id])

  @@index([branchId, createdAt])
  @@index([productId, createdAt])
  @@index([branchId, type, createdAt])
  @@index([productId, branchId, createdAt])
  @@index([stockItemId, occurredAt])
  @@index([simpleLotId, occurredAt])
  @@index([branchId, type, occurredAt])
  @@index([productId, branchId, occurredAt])
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  public_id  String   @unique
  url        String
  secure_url String
  active     Boolean  @default(true)
  productId  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  caption    String?
  isCover    Boolean?
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Product   Product[]
}

model StockItem {
  id                         Int                       @id @default(autoincrement())
  barcode                    String                    @unique
  serialNumber               String?
  receivedAt                 DateTime                  @default(now())
  warrantyDays               Int?
  expiredAt                  DateTime?
  soldAt                     DateTime?
  remark                     String?
  productId                  Int
  branchId                   Int
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  status                     StockStatus               @default(IN_STOCK)
  purchaseOrderReceiptItemId Int?
  batchNumber                String?
  checkedBy                  String?
  locationCode               String?
  qrCodeData                 String?
  source                     String?
  tag                        String?
  scannedAt                  DateTime                  @default(now())
  scannedByEmployeeId        Int?
  color                      String?
  costPrice                  Decimal?                  @db.Decimal(12, 2)
  barcodeReceiptItem         BarcodeReceiptItem[]
  repairJobs                 RepairJob[]
  repairPartUsages           RepairPartItem[]          @relation("RepairPartStockItem")
  saleItems                  SaleItem[]
  stockMovements             StockMovement[]
  stockAuditScanLog          StockAuditScanLog[]
  stockAuditSnapshotItem     StockAuditSnapshotItem[]
  branch                     Branch                    @relation(fields: [branchId], references: [id])
  product                    Product                   @relation(fields: [productId], references: [id])
  purchaseOrderReceiptItem   PurchaseOrderReceiptItem? @relation(fields: [purchaseOrderReceiptItemId], references: [id])
  scannedBy                  EmployeeProfile?          @relation(fields: [scannedByEmployeeId], references: [id])
  warrantyClaims             WarrantyClaim[]
  replacementWarrantyClaims  WarrantyClaim[]           @relation("WarrantyClaimReplacementStockItem")
  primaryServiceCases        ServiceCase[]             @relation("ServiceCasePrimaryStockItem")
  serviceCaseAssets          ServiceCaseAsset[]

  @@unique([serialNumber, productId])
  @@index([branchId, status, productId])
  @@index([productId, status])
}

model V2StockAudit {
  id        Int                @id @default(autoincrement())
  branchId  Int
  auditorId Int
  status    String             @default("PENDING")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  auditor   EmployeeProfile    @relation(fields: [auditorId], references: [id])
  branch    Branch             @relation(fields: [branchId], references: [id])
  items     V2StockAuditItem[]

  @@index([branchId])
}

model V2StockAuditItem {
  id           Int          @id @default(autoincrement())
  stockAuditId Int
  productId    Int
  expectedQty  Int
  actualQty    Int
  difference   Int
  product      Product      @relation(fields: [productId], references: [id])
  stockAudit   V2StockAudit @relation(fields: [stockAuditId], references: [id], onDelete: Cascade)
}

model Supplier {
  id                   Int                    @id @default(autoincrement())
  name                 String
  address              String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  contactPerson        String?
  country              String?                @default("Thailand")
  creditLimit          Decimal?               @default(0) @db.Decimal(12, 2)
  email                String?
  notes                String?
  paymentTerms         Int?                   @default(0)
  phone                String?
  postalCode           String?
  province             String?
  taxId                String?
  accountNumber        String?
  accountType          String?
  bankId               Int?
  branchId             Int
  active               Boolean                @default(true)
  creditBalance        Decimal?               @default(0) @db.Decimal(12, 2)
  taxBranchCode        String?                @default("00000")
  isSystem             Boolean                @default(false)
  pos                  PurchaseOrder[]
  PurchaseOrderReceipt PurchaseOrderReceipt[]
  bank                 Bank?                  @relation(fields: [bankId], references: [id])
  branch               Branch                 @relation(fields: [branchId], references: [id])
  supplierPayment      SupplierPayment[]
  warrantyClaims       WarrantyClaim[]

  @@unique([branchId, name])
}

model Bank {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  active    Boolean    @default(true)
  supplier  Supplier[]
}

model PurchaseOrder {
  id         Int                    @id @default(autoincrement())
  code       String                 @unique
  date       DateTime               @default(now())
  note       String?
  status     PurchaseOrderStatus    @default(PENDING)
  supplierId Int
  branchId   Int
  employeeId Int
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  branch     Branch                 @relation(fields: [branchId], references: [id])
  employee   EmployeeProfile        @relation(fields: [employeeId], references: [id])
  supplier   Supplier               @relation(fields: [supplierId], references: [id])
  items      PurchaseOrderItem[]
  receipts   PurchaseOrderReceipt[]
}

model PurchaseOrderItem {
  id               Int                        @id @default(autoincrement())
  productId        Int
  quantity         Int
  purchaseOrderId  Int
  receivedQuantity Int                        @default(0)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  costPrice        Decimal                    @db.Decimal(12, 2)
  product          Product                    @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder              @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receipts         PurchaseOrderReceiptItem[]
}

model PurchaseOrderReceipt {
  id                       Int                        @id @default(autoincrement())
  receivedAt               DateTime                   @default(now())
  note                     String?
  purchaseOrderId          Int?
  branchId                 Int
  receivedById             Int
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  code                     String                     @unique
  printed                  Boolean                    @default(false)
  paidAmount               Decimal?                   @db.Decimal(12, 2)
  totalAmount              Decimal?                   @db.Decimal(12, 2)
  statusPayment            PaymentStatus              @default(UNPAID)
  statusReceipt            ReceiptStatus              @default(PENDING)
  supplierTaxInvoiceDate   DateTime?
  supplierTaxInvoiceNumber String?
  vatRate                  Decimal?                   @default(7) @db.Decimal(5, 2)
  source                   ReceiptSource              @default(PO)
  supplierId               Int?
  barcodeReceiptItem       BarcodeReceiptItem[]
  inputTaxFilingItems      InputTaxFilingItem[]
  branch                   Branch                     @relation(fields: [branchId], references: [id])
  purchaseOrder            PurchaseOrder?             @relation(fields: [purchaseOrderId], references: [id])
  receivedBy               EmployeeProfile            @relation(fields: [receivedById], references: [id])
  supplier                 Supplier?                  @relation(fields: [supplierId], references: [id])
  items                    PurchaseOrderReceiptItem[]
  supplierPaymentReceipts  SupplierPaymentReceipt[]

  @@index([branchId, receivedAt])
  @@index([purchaseOrderId])
  @@index([source, receivedAt])
}

model InputTaxFilingBatch {
  id          Int                  @id @default(autoincrement())
  branchId    Int
  month       Int
  year        Int
  status      InputTaxFilingStatus @default(DRAFT)
  note        String?
  createdById Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  branch      Branch               @relation(fields: [branchId], references: [id])
  createdBy   EmployeeProfile      @relation(fields: [createdById], references: [id])
  items       InputTaxFilingItem[]

  @@index([branchId, year, month])
  @@index([status])
}

model SalesTaxFilingBatch {
  id          Int                  @id @default(autoincrement())
  branchId    Int
  month       Int
  year        Int
  status      SalesTaxFilingStatus @default(DRAFT)
  note        String?
  createdById Int
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  branch      Branch               @relation(fields: [branchId], references: [id])
  createdBy   EmployeeProfile      @relation(fields: [createdById], references: [id])
  items       SalesTaxFilingItem[]

  @@index([branchId, year, month])
  @@index([status])
}

model SalesTaxFilingItem {
  id        Int                 @id @default(autoincrement())
  batchId   Int
  saleId    Int
  createdAt DateTime            @default(now())
  batch     SalesTaxFilingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sale      Sale                @relation(fields: [saleId], references: [id])

  @@unique([batchId, saleId])
  @@index([saleId])
}

model InputTaxFilingItem {
  id                     Int                  @id @default(autoincrement())
  batchId                Int
  purchaseOrderReceiptId Int
  createdAt              DateTime             @default(now())
  batch                  InputTaxFilingBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  receipt                PurchaseOrderReceipt @relation(fields: [purchaseOrderReceiptId], references: [id])

  @@unique([batchId, purchaseOrderReceiptId])
  @@index([purchaseOrderReceiptId])
}

model PurchaseOrderReceiptItem {
  id                  Int                  @id @default(autoincrement())
  receiptId           Int
  purchaseOrderItemId Int?
  quantity            Decimal              @db.Decimal(12, 2)
  costPrice           Decimal              @db.Decimal(12, 2)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  productId           Int?
  barcodeReceiptItem  BarcodeReceiptItem[]
  product             Product?             @relation(fields: [productId], references: [id])
  purchaseOrderItem   PurchaseOrderItem?   @relation(fields: [purchaseOrderItemId], references: [id])
  receipt             PurchaseOrderReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  simpleLots          SimpleLot[]
  stockItems          StockItem[]

  @@index([receiptId])
  @@index([productId])
}

model Order {
  id              Int              @id @default(autoincrement())
  cartTotal       Decimal          @db.Decimal(12, 2)
  stripePaymentId String
  status          String
  amount          Int
  currency        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customerId      Int?
  orderStatus     OrderStatus      @default(PENDING)
  customer        CustomerProfile? @relation(fields: [customerId], references: [id])
  products        ProductOnOrder[]
}

model ProductOnOrder {
  id        Int      @id @default(autoincrement())
  productId Int
  orderId   Int
  count     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Cart {
  id                Int              @id @default(autoincrement())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  customerProfileId Int?
  userId            Int
  customerProfile   CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems         CartItem[]
}

model CartItem {
  id              Int      @id @default(autoincrement())
  cartId          Int
  productId       Int
  quantity        Int      @default(1)
  priceAtThatTime Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model ServiceOrder {
  id          Int              @id @default(autoincrement())
  customerId  Int?
  branchId    Int?
  employeeId  Int?
  receiveDate DateTime         @default(now())
  status      ServiceStatus    @default(RECEIVED)
  description String?
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       ServiceItem[]
  branch      Branch?          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer    CustomerProfile? @relation(fields: [customerId], references: [id])
  employee    EmployeeProfile? @relation(fields: [employeeId], references: [id])
}

model ServiceItem {
  id           Int          @id @default(autoincrement())
  serviceId    Int
  productId    Int?
  serialNumber String?
  problem      String?
  solution     String?
  cost         Decimal?     @db.Decimal(12, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  product      Product?     @relation(fields: [productId], references: [id])
  service      ServiceOrder @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model BarcodeCounter {
  id         Int      @id @default(autoincrement())
  branchId   Int
  yearMonth  String
  lastNumber Int
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, yearMonth])
}

